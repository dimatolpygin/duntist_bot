# ─────────────────────────────────────────────────────────────
#  Telegram (обязательно)
# ─────────────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=

# Закрытая группа «Город», куда бот шлёт карточки заказов и файлы.
# Числовой id вида -1001234567890. Бот должен состоять в этой группе.
GROUP_ID=

# ID администраторов через запятую (необязательно; на будущее для сервисных команд).
ADMIN_IDS=

# ─────────────────────────────────────────────────────────────
#  База данных (Postgres из docker-compose)
# ─────────────────────────────────────────────────────────────
# Пароль для встроенного Postgres. Задайте свой (любая строка без пробелов).
POSTGRES_PASSWORD=change_me_strong_password

# (необязательно) пользователь и имя БД встроенного Postgres.
# POSTGRES_USER=postgres
# POSTGRES_DB=postgres

# Имя схемы под этот бот (создаётся автоматически, чужие схемы не трогаются).
DB_SCHEMA=zarub

# ─────────────────────────────────────────────────────────────
#  S3 (Beget) — для больших файлов (>50 МБ). На старте можно оставить пустым.
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────
#  Прочее
# ─────────────────────────────────────────────────────────────
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
#  Только для запуска БЕЗ Docker (python -m src.main).
#  В docker-compose эти значения подставляются автоматически — здесь не нужны.
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5432/postgres
# REDIS_URL=redis://localhost:6379/0
